HOST=0.0.0.0
PORT=8011

# Optional: if you only ship unresolved feed + overrides, this is enough.
REVIEW_UNRESOLVED_FEED_PATH=data/review/unresolved_stations.json
REVIEW_OVERRIDES_PATH=data/review/coordinate_manual_overrides.csv
REVIEW_STATIC_DIR=review_site

# Optional full CSV mode (if available)
REVIEW_STATIONS_PATH=data/derived/sveltekit_app_seed/stations.csv
REVIEW_MEMBERSHIP_PATH=data/derived/sveltekit_app_seed/station_admin_membership.csv

# Strongly recommended for public deployment
REVIEW_AUTH_USER=reviewer
REVIEW_AUTH_PASSWORD=change-me

# Optional UI metric hint when running feed-only mode
REVIEW_WITH_EXACT_HINT=40028
